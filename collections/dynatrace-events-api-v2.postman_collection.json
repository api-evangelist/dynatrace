    "name": "Dynatrace Events API v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Dynatrace Events API v2 enables you to push custom events into a Dynatrace environment and retrieve event data from monitored systems. It supports creating deployment events, custom annotations, configuration events, and performance events targeting specific entities. Events ingested via this API are subject to DDU (Davis Data Units) licensing and may trigger Dynatrace AI analysis.\n\nContact Support:\n Name: Dynatrace Support",
      "type": "text/plain"
    }
  }
