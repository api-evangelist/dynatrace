{
  "@context": {
    "@version": 1.1,
    "dt": "https://dt.dynatrace.com/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Dynatrace Problem": "dt:Dynatrace Problem",
    "problemId": {
      "@id": "dt:problemId",
      "@type": "xsd:string"
    },
    "displayId": {
      "@id": "dt:displayId",
      "@type": "xsd:string"
    },
    "title": {
      "@id": "dt:title",
      "@type": "xsd:string"
    },
    "severityLevel": {
      "@id": "dt:severityLevel",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "dt:status",
      "@type": "xsd:string"
    },
    "startTime": {
      "@id": "dt:startTime",
      "@type": "xsd:integer"
    },
    "endTime": {
      "@id": "dt:endTime",
      "@type": "xsd:integer"
    },
    "affectedEntities": {
      "@id": "dt:affectedEntities",
      "@container": "@set"
    },
    "impactedEntities": {
      "@id": "dt:impactedEntities",
      "@container": "@set"
    },
    "rootCauseEntity": {
      "@id": "dt:rootCauseEntity",
      "@type": "xsd:string"
    },
    "managementZones": {
      "@id": "dt:managementZones",
      "@container": "@set"
    },
    "tags": {
      "@id": "dt:tags",
      "@container": "@set"
    },
    "evidenceDetails": {
      "@id": "dt:evidenceDetails"
    },
    "comments": {
      "@id": "dt:comments"
    }
  }
}