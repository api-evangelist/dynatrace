      "item": [
        {
          "id": "d3259829-dd3f-474a-8f65-c575a569dc32",
          "name": "Dynatrace List Events",
          "request": {
            "name": "Dynatrace List Events",
            "description": {
              "content": "Returns a list of events from the Dynatrace environment matching the specified filters. Results are paginated; use nextPageKey from the response to retrieve additional pages. Time range defaults to the last two hours if not specified.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "events"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "nextPageKey",
                  "value": "<string>",
                  "description": "The cursor for the next page of results, obtained from the nextPageKey field of a previous response. When this parameter is set, all other query parameters except pageSize are ignored."
                },
                {
                  "disabled": false,
                  "key": "pageSize",
                  "value": "50",
                  "description": "The number of events to return per page. Default is 50, maximum is 1000."
                },
                {
                  "disabled": false,
                  "key": "from",
                  "value": "<string>",
                  "description": "The start of the queried time range. Use a relative expression (now-1h), ISO 8601 timestamp, or Unix timestamp in milliseconds. Default is now-2h."
                },
                {
                  "disabled": false,
                  "key": "to",
                  "value": "<string>",
                  "description": "The end of the queried time range. Use a relative expression (now), ISO 8601 timestamp, or Unix timestamp in milliseconds. Default is now."
                },
                {
                  "disabled": false,
                  "key": "eventSelector",
                  "value": "<string>",
                  "description": "Defines the scope of the query using the event selector syntax. For example, eventType(\"CUSTOM_DEPLOYMENT\") to filter by type, or title(\"My event\") to filter by title. Multiple conditions can be combined."
                },
                {
                  "disabled": false,
                  "key": "entitySelector",
                  "value": "<string>",
                  "description": "Filters events to those affecting entities matching this selector. Use the standard entity selector syntax, e.g., type(HOST),tag(prod)."
                },
                {
                  "disabled": false,
                  "key": "eventType",
                  "value": "<string>",
                  "description": "Filters results to events of the specified type. For a full list of types, see the eventType enum in EventIngestPayload."
                }
              ],
              "variable": [
                {
                  "description": "The unique identifier of your Dynatrace environment",
                  "type": "any",
                  "value": "{{environmentId}}",
                  "key": "environmentId"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
