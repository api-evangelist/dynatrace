{
  "@context": {
    "@version": 1.1,
    "dt": "https://dt.dynatrace.com/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "WebhookNotificationConfig": "dt:WebhookNotificationConfig",
    "type": {
      "@id": "dt:type",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "active": {
      "@id": "dt:active",
      "@type": "xsd:boolean"
    },
    "url": {
      "@id": "schema:url",
      "@type": "xsd:string"
    },
    "alertingProfile": {
      "@id": "dt:alertingProfile",
      "@type": "xsd:string"
    },
    "headers": {
      "@id": "dt:headers",
      "@container": "@set"
    },
    "acceptAnyCertificate": {
      "@id": "dt:acceptAnyCertificate",
      "@type": "xsd:boolean"
    },
    "payload": {
      "@id": "dt:payload",
      "@type": "xsd:string"
    }
  }
}