        "path": {
          "@id": "ns:path",
          "@type": "xsd:string"
        },
        "message": {
          "@id": "ns:message",
          "@type": "xsd:string"
        },
        "parameterLocation": {
          "@id": "ns:parameterLocation",
          "@type": "xsd:string"
        },
