{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/dynatrace/refs/heads/main/json-schema/account-management-api-permission-collection-schema.json",
  "title": "PermissionCollection",
  "description": "A collection of permission assignments for the account.",
  "type": "object",
  "properties": {
    "permissions": {
      "type": "array",
      "description": "The list of all permissions in the account.",
      "items": {
        "$ref": "#/components/schemas/Permission"
      },
      "example": [
        {
          "permissionName": "Production Service",
          "scope": "example-value",
          "scopeType": "ACCOUNT",
          "groupId": "abc123"
        }
      ]
    }
  }
}